{
  "name": "philo-art-backend",
  "version": "0.1.1",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "cross-env NODE_ENV=production node ./dist/index.js",
    "dev": "cross-env NODE_ENV=development tsx --watch ./src/index.ts",
    "stage": "cross-env NODE_ENV=stage node ./dist/index.js",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\"",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "test": "dotenv -e .env.test -- vitest run",
    "test:watch": "dotenv -e .env.test -- vitest",
    "test:coverage": "dotenv -e .env.test -- vitest run --coverage",
    "test:integration": "dotenv -e .env.test -- vitest run tests/integration",
    "test:e2e": "dotenv -e .env.test -- vitest run tests/e2e"
  },
  "author": "Philo",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@faker-js/faker": "^9.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/body-parser": "^1.19.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.10.2",
    "@types/superagent": "^8.1.9",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.8",
    "dotenv-cli": "^8.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.4.2",
    "prisma": "^6.1.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@apollo/server": "^4.11.2",
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@graphql-tools/schema": "^10.0.11",
    "@prisma/client": "^6.1.0",
    "axios": "^0.21.0",
    "bcrypt": "^5.1.1",
    "body-parser": "^2.2.2",
    "cheerio": "^1.0.0-rc.5",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dataloader": "^2.0.0",
    "date-fns": "^2.16.1",
    "dotenv": "^16.4.5",
    "exif-reader": "^2.0.3",
    "express": "^4.21.2",
    "got": "^11.8.1",
    "graphql": "^16.9.0",
    "graphql-scalars": "^1.24.0",
    "jsonwebtoken": "^8.5.1",
    "lodash-es": "^4.17.23",
    "lru-cache": "^6.0.0",
    "multer": "^1.4.4",
    "nanoid": "^3.1.22",
    "pexels": "^1.0.1",
    "pg": "^8.5.1",
    "query-string": "^7.0.0",
    "sharp": "^0.34.5",
    "superagent": "^6.1.0",
    "uuid": "^8.3.1",
    "winston": "^3.3.3",
    "yup": "^0.30.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/philo-li/philo-art-backend.git"
  },
  "bugs": {
    "url": "https://github.com/philo-li/philo-art-backend/issues"
  },
  "homepage": "https://github.com/philo-li/philo-art-backent#readme",
  "description": ""
}
